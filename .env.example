## VAULTWARDEN ###
VAULTWARDEN_DOMAIN="https://your-domain.com" # domain must be HTTPS
VAULTWARDEN_ADMIN_TOKEN='generate-argon2-hash-for-admin-token-and-paste-here' # docker run --rm -it vaultwarden/server /vaultwarden hash
VAULTWARDEN_SIGNUPS_ALLOWED=true # set to false after creating your admin user to prevent unauthorized signups
VAULTWARDEN_INVITATIONS_ALLOWED=false
VAULTWARDEN_LOG_LEVEL="info"
VAULTWARDEN_EXTENDED_LOGGING=true
VAULTWARDEN_PORT=8359
### END VAULTWARDEN ###

### SHARED ###
# General settings
TZ="America/New_York"

# Azure Foundry (OpenAI Models) - optional if using ollama models
AZURE_FOUNDRY_API_KEY="replace-with-your-azure-openai-api-key"
AZURE_FOUNDRY_BASE_URL="https://your-resource.services.ai.azure.com"
AZURE_FOUNDRY_OPENAI_BASE_URL="https://your-resource.services.ai.azure.com/openai/v1"

# Ollama - optional if using azure foundry models
OLLAMA_BASE_URL="http://host.docker.internal:11434"
# api key optional, local models run without it (for Ollama cloud models only)
OLLAMA_API_KEY="replace-with-your-ollama-api-key"

# LM Studio - optional
LM_STUDIO_OPENAI_API_URL="http://host.docker.internal:1234/v1"

# Context7 - optional
CONTEXT7_API_KEY="replace-with-your-context7-api-key"

# Jina - optional
JINA_API_KEY="replace-with-your-jina-api-key"

# Unsplash - optional
UNSPLASH_ACCESS_KEY="replace-with-your-unsplash-access-key"
UNSPLASH_SECRET_KEY="replace-with-your-unsplash-secret-key"
### END SHARED ###
