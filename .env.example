### SEARXNG ###
SEARXNG_SECRET_KEY="replace-with-a-long-random-secret" # openssl rand -hex 32
### END SEARXNG ###

### OPEN WEBUI ###
# Main App
OPEN_WEBUI_PORT=3000
OPEN_WEBUI_SECRET_KEY="replace-with-a-long-random-secret" # openssl rand -hex 32
OPEN_WEBUI_AUTH=true # set false to disable login authentication

# Admin user
OPEN_WEBUI_ADMIN_EMAIL="your-email@example.com"
OPEN_WEBUI_ADMIN_PASSWORD="replace-with-a-strong-password"
OPEN_WEBUI_ADMIN_NAME="Your Name"

# PostgreSQL / pgvector
OPEN_WEBUI_POSTGRES_DB="openwebui"
OPEN_WEBUI_POSTGRES_USER="openwebui"
OPEN_WEBUI_POSTGRES_PASSWORD="replace-with-a-strong-password"
### END OPEN WEBUI ###

### OPEN NOTEBOOK ###
OPEN_NOTEBOOK_ENCRYPTION_KEY="replace-with-a-long-random-secret" # openssl rand -hex 32
### END OPEN NOTEBOOK ###

### KARAKEEP ###
# secrets
KARAKEEP_MEILI_MASTER_KEY="replace-with-a-strong-meilisearch-key" # openssl rand -hex 32
KARAKEEP_NEXTAUTH_SECRET="replace-with-a-long-random-secret" # openssl rand -hex 32

# inference models/settings - ollama
KARAKEEP_INFERENCE_TEXT_MODEL="gemma4"
KARAKEEP_INFERENCE_IMAGE_MODEL="gemma4"
KARAKEEP_EMBEDDING_TEXT_MODEL="embeddinggemma"
KARAKEEP_INFERENCE_NUM_WORKERS=1
KARAKEEP_OLLAMA_KEEP_ALIVE="5m"
KARAKEEP_INFERENCE_JOB_TIMEOUT_SEC=90

# inference models/settings - azure foundry
# KARAKEEP_INFERENCE_TEXT_MODEL="gpt-5.4-mini"
# KARAKEEP_INFERENCE_IMAGE_MODEL="gpt-5.4-mini"
# KARAKEEP_EMBEDDING_TEXT_MODEL="text-embedding-3-small"
# KARAKEEP_INFERENCE_USE_MAX_COMPLETION_TOKENS=true
# KARAKEEP_INFERENCE_NUM_WORKERS=4

# inference settings - shared
KARAKEEP_INFERENCE_ENABLE_AUTO_SUMMARIZATION=true
### END KARAKEEP ###

